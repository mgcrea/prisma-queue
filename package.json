{
  "name": "@mgcrea/prisma-queue",
  "version": "2.0.0",
  "keywords": [
    "job",
    "postgresql",
    "prisma",
    "queue",
    "worker"
  ],
  "license": "MIT",
  "author": "Olivier Louvignes <olivier@mgcrea.io>",
  "repository": "github:mgcrea/fastify-session-prisma-store",
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "require": "./dist/index.cjs",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "start": "DEBUG=prisma-queue,prisma-query vitest",
    "build": "tsup",
    "lint": "oxlint src/ test/",
    "format": "oxfmt --write src/ test/",
    "format:check": "oxfmt --check src/ test/",
    "check": "tsc --noEmit",
    "spec": "DEBUG=prisma-queue,prisma-query vitest --run --pool=forks",
    "coverage": "DEBUG=prisma-queue,prisma-query vitest --run --pool=forks --coverage",
    "dev": "DEBUG=prisma-queue vitest --watch --pool=forks --reporter=dot",
    "test": "pnpm run lint && pnpm run check && pnpm run spec && pnpm run format:check",
    "prepare": "prisma generate",
    "reset": "prisma db push --force-reset && prisma generate",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "croner": "^10.0.1",
    "debug": "^4.4.3"
  },
  "devDependencies": {
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "@tsconfig/node-lts": "^24.0.0",
    "@tsconfig/strictest": "^2.0.8",
    "@types/debug": "^4.1.12",
    "@types/node": "^24.10.6",
    "@vitest/coverage-v8": "^4.1.0",
    "dotenv-cli": "^11.0.0",
    "oxfmt": "^0.40.0",
    "oxlint": "^1.55.0",
    "prisma": "^7.5.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.0"
  },
  "peerDependencies": {
    "@prisma/adapter-pg": ">=7",
    "@prisma/client": ">=7"
  },
  "engines": {
    "node": ">=12"
  },
  "packageManager": "pnpm@10.32.1"
}
